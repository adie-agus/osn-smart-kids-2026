{
  "entities": {
    "LeaderboardEntry": {
      "title": "Leaderboard Entry",
      "description": "A record of a user's quiz score.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "name": { "type": "string" },
        "school": { "type": "string" },
        "grade": { "type": "string" },
        "subject": { "type": "string" },
        "mode": { "type": "string" },
        "score": { "type": "number" },
        "timeSpent": { "type": "number" },
        "date": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "name", "score", "date"]
    }
  },
  "firestore": {
    "leaderboard": {
      "schema": "LeaderboardEntry",
      "description": "Collection of all student quiz scores for the national leaderboard."
    }
  }
}
